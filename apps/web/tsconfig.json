{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"jsx": "react-jsx",
		"moduleResolution": "Bundler",
		"module": "ESNext",
		"target": "ES2022",
		"skipLibCheck": true,
		"strictNullChecks": true,
		"types": ["vite/client", "node"],
		"baseUrl": ".",
		"ignoreDeprecations": "6.0",
		"paths": {
			"@/*": ["src/*"]
		}
	},
	"include": ["src/**/*", "vite.config.ts"],
	"exclude": ["node_modules", ".output", ".nitro", ".tanstack"]
}
