DATABASE_URL=postgresql://quoteom:quoteom@localhost:5432/quoteom?schema=public
API_PORT=3001
WEB_ORIGIN=http://localhost:3000
NODE_ENV=development

# Auth.js
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=
# Must match the WEB origin (where the user's browser sits). The Vite proxy on the web
# forwards /api/* to the API. With AUTH_URL pointing at the web origin, Auth.js generates
# magic-link callback URLs that the browser hits on localhost:3000 → cookies get scoped
# to localhost:3000 (same as the web app), so cross-origin SameSite blocks don't fire.
# We only need this on PROD
AUTH_URL=http://localhost:3000/api/auth
AUTH_TRUST_HOST=true

# Encryption key for OAuth refresh/access/id tokens stored on `Account` rows.
# Generate with: openssl rand -hex 32
# Must be 64 hex chars (32 bytes). Use a different key per environment.
TOKEN_ENCRYPTION_KEY=

# Resend (email magic-link provider)
# Leave RESEND_API_KEY empty in dev — magic links are logged to console instead.
# Get a free key at https://resend.com (100 emails/day).
RESEND_API_KEY=
# In dev you can use the built-in `onboarding@resend.dev` sender (default).
# In prod use an address on a domain you've verified in your Resend dashboard.
RESEND_EMAIL_FROM=onboarding@resend.dev

# Google OAuth — leave empty to disable BOTH sign-in and Gmail inbox-connect.
# One Google Cloud OAuth client is reused for two flows:
#   1. Sign-in (Auth.js)         — scopes: openid email profile
#                                   redirect URI: ${WEB_ORIGIN}/api/auth/callback/google
#   2. Gmail inbox-connect (W3.1) — scopes: gmail.readonly + gmail.send
#                                   redirect URI: ${WEB_ORIGIN}/api/email/gmail/callback
# Register BOTH redirect URIs under the same client at console.cloud.google.com.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Entra (Azure AD) — leave empty to disable the provider
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Stripe billing
# Test mode keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
# After creating a Product + recurring Price (e.g. €149/mo) in the Stripe Dashboard,
# copy the price ID (starts with `price_`) here.
STRIPE_PRICE_ID=
# Webhook signing secret. In dev: `stripe listen --forward-to localhost:3001/api/billing/webhook`
# prints a `whsec_...` value. Paste it here. The signing secret is different in prod
# (one per webhook endpoint configured in the dashboard).
STRIPE_WEBHOOK_SECRET=

# Inngest — workers + scheduled jobs (W3.3+).
# Local dev workflow:
#   1. Run the API: npm run dev
#   2. In a second terminal: `npx inngest-cli@latest dev` (auto-discovers /api/inngest)
#   3. Open the dev dashboard at http://localhost:8288 to trigger + observe runs
# Leave both keys empty in dev — the CLI handles auth at the localhost boundary.
# In production both are required (get them from Inngest Cloud → Settings → Keys).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
